# macOS
.DS_Store

# Xcode / build output
build/
DerivedData/
*.xcuserstate
*.xcuserdatad/
xcuserdata/

# Elek.xcodeproj is generated by XcodeGen (run `xcodegen generate` after editing
# project.yml), but committed so Xcode Cloud / CI can build without XcodeGen.
# Per-user state inside it stays ignored (xcuserdata/ rule above).

# Compiled seed generator (rebuilt by scripts/build-seed.sh).
# The compiled Elek/Resources/blocklist.bin IS committed.
tools/seedgen/seedgen

# Signing material — NEVER commit. Certificates and (especially) private keys.
*.cer
*.pem
*.p12
*.p8
*.key
*.csr
*.mobileprovision

# Cloudflare Worker (worker/)
worker/node_modules/
worker/.wrangler/
worker/.dev.vars
# HaGeZi-derived filter is GPLv3 — generated at deploy time, NEVER committed
# (redistribution). Build it with worker/scripts/build-blocklist.sh.
worker/blocklist.bin

# App-side resolver token (mirrors the Worker AUTH_TOKEN secret). Never commit.
Elek/Secrets.xcconfig
