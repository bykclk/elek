    "System-wide · DNS level" : {
      "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Sistem genelinde · DNS düzeyinde" } } }
    },
    "Turn on protection" : {
      "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Korumayı aç" } } }
    },
    "Elek installs a private, on-device DNS filter that blocks ads and trackers across every app. iOS will now ask permission to add a proxy configuration. Your browsing data never leaves your device." : {
      "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Elek, tüm uygulamalarda reklamları ve izleyicileri engelleyen özel, cihaz üzerinde çalışan bir DNS filtresi kurar. iOS şimdi bir proxy yapılandırması eklemek için izin isteyecek. Tarama verilerin cihazından hiç çıkmaz." } } }
    },
    "Continue" : {
      "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Devam et" } } }
    },
    "Not now" : {
      "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Şimdi değil" } } }
    },
    "Couldn’t turn on protection" : {
      "localizations" : { "tr" : { "stringUnit" : { "state" : "translated", "value" : "Koruma açılamadı" } } }
    },
