            "value" : "Devam et"
          }
        }
      }
    },
    "Couldn’t turn on protection" : {
      "extractionState" : "stale",
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koruma açılamadı"
