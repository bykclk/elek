{
  "sourceLanguage" : "en",
  "strings" : {
    "Ads and trackers are being blocked on your device." : {
      "extractionState" : "stale",
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reklamlar ve izleyiciler cihazında engelleniyor."
          }
        }
      }
    },
    "Continue" : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Devam et"
          }
        }
      }
    },
    "Couldn’t turn on protection" : {
      "extractionState" : "stale",
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koruma açılamadı"
          }
        }
      }
    },
    "Elek" : {
      "shouldTranslate" : false
    },
    "Elek installs a private, on-device DNS filter that blocks ads and trackers across every app. iOS will now ask permission to add a VPN configuration — it’s a local filter only: there is no VPN server, and your browsing data never leaves your device." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elek, tüm uygulamalarda reklamları ve izleyicileri engelleyen özel, cihaz üzerinde çalışan bir DNS filtresi kurar. iOS şimdi bir VPN yapılandırması eklemek için izin isteyecek — bu yalnızca yerel bir filtredir: VPN sunucusu yoktur ve tarama verilerin cihazından hiç çıkmaz."
          }
        }
      }
    },
    "Protection couldn’t start. Please try again." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Koruma başlatılamadı. Lütfen tekrar dene."
          }
        }
      }
    },
    "Filtering is paused. Tap to turn on." : {
      "extractionState" : "stale",
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Filtreleme şu an duraklatıldı. Açmak için dokun."
